# Bot
DISCORD_TOKEN=

# OAuth (dashboard + slash registration)
# IMPORTANT: enable scope "guilds" in Discord Developer Portal OAuth2 settings if not auto-added.
DISCORD_CLIENT_ID=
# Secret OAuth2 (onglet « OAuth2 » du portail) — ce n’est pas DISCORD_TOKEN.
DISCORD_CLIENT_SECRET=
OAUTH_CALLBACK_URL=http://localhost:3000/auth/discord/callback

# Web session
SESSION_SECRET=replace_with_a_long_random_secret_at_least_16_chars

# Planning web : salon d’annonce (recommandé)
PLANNER_CHANNEL_ID=

# Rappels Discord : nom + logo (auteur d’embed). PUBLIC_APP_URL sans slash final = URL du logo /branding/firelegends-logo.png
PUBLIC_APP_URL=
PLANNER_BRANDING_DISPLAY_NAME=FireLegends
# Optionnel : URL https complète d’une autre image (prioritaire sur le fichier branding)
PLANNER_BRANDING_ICON_URL=
# Qui peut gérer la liste des membres autorisés à créer des événements (IDs Discord, CSV). Souvent le même que DASHBOARD_ALLOWED_USER_IDS.
PLANNER_ADMIN_USER_IDS=

# Dashboard access (user ids and/or guild roles)
DASHBOARD_ALLOWED_USER_IDS=
DASHBOARD_GUILD_ID=
PLANNER_GUILD_ID=
# Si DASHBOARD_GUILD_ID est vide, PLANNER_GUILD_ID sert aussi pour les contrôles OAuth (membre + rôles).
DASHBOARD_ALLOWED_ROLE_IDS=

# Secours si OAuth Discord est bloqué (Cloudflare 429) depuis l’hébergeur : mot de passe fort (≥16 car.).
# Le bot (DISCORD_TOKEN) reste utilisé pour rappels + enrichissement profil ; les événements restent liés à la guilde / salons configurés.
# Session = même droits que cet ID Discord (obligatoire dans DASHBOARD_ALLOWED_USER_IDS, ou une seule ID dans la liste).
DASHBOARD_PASSWORD=
DASHBOARD_PASSWORD_ACT_AS_USER_ID=
# Optionnel : guildes pour la session mot de passe (CSV). Sinon DASHBOARD_GUILD_ID / PLANNER_GUILD_ID.
DASHBOARD_PASSWORD_GUILD_IDS=

# Slash command managers (non-admins): comma-separated role ids
BOT_MANAGE_ROLE_IDS=

# Défaut pour les nouveaux événements : plus petit entier de la liste (ex. « 10,5 » → 5). Le délai réel est réglé par événement dans le planning (onglet Rappel Discord). Un seul rappel Discord par événement.
REMINDER_MINUTES=5

# Optionnel : clé API DeepL — si le modèle de rappel (corps d’embed) est en français, il est traduit en anglais à l’envoi sur Discord (rappels + boutons RSVP + aperçu admin). Compte gratuit : clé se terminant par :fx sur https://www.deepl.com/pro-api
DEEPL_AUTH_KEY=

PORT=3000
NODE_ENV=development

DATABASE_PATH=events.db
SCHEDULER_TIMEZONE=Etc/UTC

# --- Hébergement Render (https://render.com) ---
# OAUTH_CALLBACK_URL et PUBLIC_APP_URL : URL publique https du service (sans slash final), ex. https://alliancebot-manager.onrender.com
# OAuth Discord : ajoutez la même URL + /auth/discord/callback dans le portail développeur (Redirects).
# Plan gratuit : le disque est réinitialisé au redéploiement. Pour garder la base SQLite, ajoutez un disque Render et mettez p.ex. DATABASE_PATH=/data/events.db
